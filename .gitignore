# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
*.egg-info/

# ─── Generated / temporary lab files ──────────────────────
# Decoded copies of the Udemy .mhtml archives (regenerated via scripts/decode_mhtml.py)
lab/*.decoded.html
# Scratch/dump files produced while (re)building the labs
scripts/_*.txt
scripts/_*.md
scripts/*.tmp

# ─── LaTeX build artifacts ────────────────────────────────
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.nav
*.snm

# ─── Editor / IDE ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS junk ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
